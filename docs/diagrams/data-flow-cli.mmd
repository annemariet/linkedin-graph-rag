        ENRICH --> NEO2["Neo4j + Knowledge Nodes"]
        NEO2 --> INDEX["index_content"]
        INDEX --> CHUNKS["Chunk nodes + embeddings\nVector index"]
        CHUNKS --> QUERY["query_graphrag\nSemantic search"]
    end
